# Copy this to .env.local and fill in your real values. Never commit .env.local.

# Postgres connection string (Supabase, Neon, Railway all give you this directly)
DATABASE_URL=postgres://user:password@host:5432/dbname

# From Stripe Dashboard > Developers > API keys
# Use your SECRET key here (starts with sk_live_ or sk_test_) — never the publishable key
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# From Stripe Dashboard > Developers > Webhooks > [your endpoint] > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Your deployed site URL (e.g. https://tikilees.com or your Vercel URL)
SITE_URL=https://your-site-url.com
